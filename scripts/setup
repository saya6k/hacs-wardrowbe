#!/usr/bin/env bash
# Wire this checkout into the devcontainer's baked-in Home Assistant install.
#
# The devcontainer base image (see .devcontainer/devcontainer.json) is the
# official homeassistant/home-assistant image, pinned to a dev-branch nightly.
# The image tag must match tests/requirements_test.txt's homeassistant pin —
# one version string shared between the two. hacs.json's `homeassistant`
# floor stays the end-user-facing 2026.8.0b0; move the image tag and
# requirements pin to `>=2026.8.0b0` too once that beta ships.
#
# Unlike a generic Python devcontainer, the image already bundles HA core, the
# frontend, and every native/runtime dependency default_config needs (ffmpeg,
# go2rtc, PyTurboJPEG, aioesphomeapi, bleak, hassil, home-assistant-intents)
# — so there is nothing to apt/apk here beyond the dev-only Python tools the
# runtime image doesn't ship. homeassistant in requirements_test.txt is
# satisfied by the image's preinstalled copy.
set -euo pipefail

cd "$(dirname "$0")/.."

pip3 install --no-cache-dir -r tests/requirements_test.txt ruff mypy colorlog

mkdir -p config
if [ ! -f config/configuration.yaml ]; then
  cat > config/configuration.yaml <<'YAML'
# ha_wardrowbe devcontainer configuration.
# Identity values keep this dev instance distinct from any production HA
# on the host network. Adjust latitude/longitude/time_zone for your locale.
homeassistant:
  name: ha_wardrowbe Dev
  latitude: 0
  longitude: 0
  elevation: 0
  unit_system: metric
  time_zone: UTC
  external_url: "http://hacs-wardrowbe-dev:8123"
  internal_url: "http://hacs-wardrowbe-dev:8123"

default_config:

http:
  server_port: 8123

logger:
  default: info
  logs:
    custom_components.wardrowbe: debug
YAML
fi

# Symlink the integration into HA's config dir so edits hot-reload.
mkdir -p config/custom_components
ln -sfn "$PWD/custom_components/wardrowbe" config/custom_components/wardrowbe

echo "Setup complete."
echo "  scripts/develop  → run HA from this checkout (port 8123)"
echo "  scripts/test     → run pytest + ruff + mypy"
